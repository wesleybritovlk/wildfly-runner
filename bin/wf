#!/bin/bash
SOURCE_DIR=$(dirname $(readlink -f $0))/..
source $SOURCE_DIR/core/bootstrap.sh
source $SOURCE_DIR/core/network.sh
source $SOURCE_DIR/core/instance.sh
source $SOURCE_DIR/core/maven.sh
source $SOURCE_DIR/core/initializer.sh
source $SOURCE_DIR/core/projects.sh
source $SOURCE_DIR/core/engines.sh

setup_structure

show_help() {
    echo -e "\n\e[1;34mWILDFLY RUNNER CLI\e[0m"
    echo -e "Uso: \e[32mwf [comando] [argumentos]\e[0m\n"
    echo -e "\e[1mCOMANDOS:\e[0m"
    echo -e "  \e[32minit [nome]\e[0m           Inicializa um novo projeto"
    echo -e "  \e[32mrun [-d|-t|-f] [nome]\e[0m      Compila e roda o projeto (\e[33m-d\e[0m ativa o Debug|\e[33m-t\e[0m ativa o Testes|\e[33m-f\e[0m FAST run   sem rebuild)"
    echo -e "  \e[32mdeploy [-t|-P profiles] [nome]\e[0m    Compila e gera o package do projeto (\e[33m-t\e[0m ativa o Testes|\e[33m-P\e[0m define os profiles)"
    echo -e "  \e[32mprofiles [nome]\e[0m       Configura os profiles Maven do projeto"
    echo -e "  \e[32mlist\e[0m                  Lista projetos, versões e caminhos"
    echo -e "  \e[32mstatus [nome]\e[0m         Mostra status de execução e portas detalhadas"
    echo -e "  \e[32mupdate [nome]\e[0m         Atualiza o projeto motores e caminhos"
    echo -e "  \e[32mremove [nome]\e[0m         Remove o projeto (opcionalmente o código)"
    echo -e "\n\e[1mGERENCIAMENTO DE MOTORES (ENGINES):\e[0m"
    echo -e "  \e[32mengine list\e[0m           Lista Mavens e WildFlys baixados"
    echo -e "  \e[32mengine install [tipo]\e[0m Instala novo [maven|wildfly]"
    echo -e "  \e[32mengine remove [tipo]\e[0m  Remove um motor instalado [maven|wildfly]"
    echo ""
}

case "$1" in
    init)
        NAME=$2
        if [ -z "$NAME" ]; then
            read -p "Digite o nome do projeto: " NAME
        fi
        [ -z "$NAME" ] && echo "Erro: Nome do projeto obrigatorio" && exit 1
        PROJECT_DIR="$SOURCE_DIR/projects/$NAME"
        mkdir -p "$PROJECT_DIR"
        install_engines "$NAME"
        setup_repository "$NAME" "$PROJECT_DIR"
        REPO_FLOW=$?
        source "$PROJECT_DIR/.engine-versions"
        REPO_PATH=$(cat "$PROJECT_DIR/.repo-path")
        cp $SOURCE_DIR/templates/.env.example "$PROJECT_DIR/.env"
        cp $SOURCE_DIR/templates/.profiles.example "$PROJECT_DIR/.profiles"
        touch "$PROJECT_DIR/java-args"
        configure_profiles "$PROJECT_DIR" "$REPO_PATH" "$MVN_PATH"
        echo -e "\n================================================================"
        [ "$REPO_FLOW" -eq 2 ] && echo "INFO: Criando standalone.xml base em $PROJECT_DIR/standalone.xml" || echo "AVISO: Copie seu standalone.xml para: $PROJECT_DIR/"
        echo -e "================================================================"
        echo -e "Projeto configurado com sucesso! Para rodar: wf run $NAME"
        echo -e "================================================================\n"
        ;;
    list|status|update|remove)
        CMD=$1
        ARG=$2
        case "$CMD" in
            list) list_projects ;;
            status) show_status "$ARG" ;;
            update) update_project "$ARG" ;;
            remove) remove_project "$ARG" ;;
        esac
        ;;
    engine)
        CMD=$2; shift 2;
        case "$CMD" in
            list) list_engines ;;
            remove) remove_engine "$@" ;;
            install) install_engine_generic "$@" ;;
            *) show_help ;;
        esac
        ;;
    profiles)
        configure_profiles_cmd "$2"
        ;;
    deploy)
        SKIP_TESTS="-DskipTests"
        PROFILES_ARG=""
        shift
        while getopts "tP:" opt; do
            case $opt in
                t) SKIP_TESTS="" ;;
                P) PROFILES_ARG="$OPTARG" ;;
            esac
        done
        shift $((OPTIND -1))
        NAME=$1
        if [ -z "$NAME" ]; then
            projects=($(ls -d $SOURCE_DIR/projects/*/ 2>/dev/null | xargs -n1 basename))
            if [ ${#projects[@]} -eq 0 ]; then
                echo "Erro: Nenhum projeto configurado." && exit 1
            fi
            echo "Selecione o projeto para rodar:"
            for i in "${!projects[@]}"; do printf "  %2d) %s\n" "$((i+1))" "${projects[$i]}"; done
            read -p "Escolha (1): " choice
            choice=${choice:-1}
            NAME=${projects[$((choice-1))]}
        fi
        PROJECT_DIR="$SOURCE_DIR/projects/$NAME"
        source "$PROJECT_DIR/.engine-versions"
        REPO_PATH=$(cat "$PROJECT_DIR/.repo-path")
        if [ -z "$PROFILES_ARG" ]; then
            read -p "Deseja definir perfis Maven para este deploy? (Vazio para usar salvos): " PROFILES_ARG
            [ -z "$PROFILES_ARG" ] && PROFILES_ARG=$(cat "$PROJECT_DIR/.profiles" | xargs | tr ' ' ',')
        fi
        check_maven_profiles "$REPO_PATH" "$PROFILES_ARG" "$MVN_PATH"
        build_project "$REPO_PATH" "$PROFILES_ARG" "$MVN_PATH" "package" "$SKIP_TESTS"
        echo -e "\n\e[32mDeploy (Package) concluído para $NAME!\e[0m"
        ;;
    run)
        DEBUG=false
        SKIP_TESTS="-DskipTests"
        FAST_MODE=false
        shift
        while getopts "dtf" opt; do
            case $opt in
                d) DEBUG=true ;;
                t) SKIP_TESTS="" ;;
                f) FAST_MODE=true ;;
            esac
        done
        shift $((OPTIND -1))
        NAME=$1
        if [ -z "$NAME" ]; then
            projects=($(ls -d $SOURCE_DIR/projects/*/ 2>/dev/null | xargs -n1 basename))
            if [ ${#projects[@]} -eq 0 ]; then
                echo "Erro: Nenhum projeto configurado." && exit 1
            fi
            echo "Selecione o projeto para rodar:"
            for i in "${!projects[@]}"; do printf "  %2d) %s\n" "$((i+1))" "${projects[$i]}"; done
            read -p "Escolha (1): " choice
            choice=${choice:-1}
            NAME=${projects[$((choice-1))]}
        fi
        PROJECT_DIR="$SOURCE_DIR/projects/$NAME"
        if [ ! -d "$PROJECT_DIR" ]; then
            echo "Erro: Projeto nao encontrado: $NAME" && exit 1
        fi
        source "$PROJECT_DIR/.engine-versions"
        shell_java_home=$(readlink -f "$(which java)" | sed 's|/bin/java||')
        if [ "$shell_java_home" != "$JAVA_HOME" ]; then
            echo -e "\e[33mAVISO: O Java do shell ($shell_java_home) e diferente do configurado no projeto ($JAVA_HOME).\e[0m"
            echo -e "Forçando execucao com Java configurado: $JAVA_VER"
        fi
        export JAVA_HOME="$JAVA_HOME"
        export PATH="$JAVA_HOME/bin:$PATH"
        export JAVA="$JAVA_HOME/bin/java"
        WF_BASE_PATH="$SOURCE_DIR/engines/wildfly-$WF_SELECTED_VER"
        REPO_PATH=$(cat "$PROJECT_DIR/.repo-path")
        XML_PATH=$(ls "$PROJECT_DIR"/*.xml 2>/dev/null | head -n 1)
        [ -z "$XML_PATH" ] && echo "Erro: standalone.xml nao encontrado" && exit 1
        OFFSET=$(find_dynamic_offset "$XML_PATH" "$DEBUG")
        RUNTIME_DIR=$(prepare_runtime "$NAME" "$XML_PATH" "$WF_BASE_PATH")
        JVM_OPTS="$(cat $SOURCE_DIR/global.jvm | xargs) $(cat $PROJECT_DIR/java-args | xargs)"
        if [ -f "$PROJECT_DIR/.env" ]; then
            while IFS='=' read -r key value || [ -n "$key" ]; do
                [[ $key =~ ^#.* ]] && continue
                [[ -z $key ]] && continue
                clean_value=$(echo "$value" | tr -d '\r' | xargs)
                JVM_OPTS="$JVM_OPTS -D$key=$clean_value"
                export "$key=$clean_value"
            done < "$PROJECT_DIR/.env"
        fi
        JVM_OPTS=$(echo "$JVM_OPTS" | sed 's/-agentlib:jdwp=[^ ]*//g')
        if [ "$DEBUG" = true ]; then
            FINAL_DEBUG_PORT=$((8687 + OFFSET))
            JVM_OPTS="$JVM_OPTS -agentlib:jdwp=transport=dt_socket,server=y,suspend=n,address=$FINAL_DEBUG_PORT"
        fi
        if [ "$FAST_MODE" = false ]; then
            PROFILES=$(cat "$PROJECT_DIR/.profiles" | xargs | tr ' ' ',')
            check_maven_profiles "$REPO_PATH" "$PROFILES" "$MVN_PATH"
            build_project "$REPO_PATH" "$PROFILES" "$MVN_PATH" "install" "$SKIP_TESTS"
        else
            echo -e "\e[32mModo FAST ativado: Pulando build e procurando WAR existente...\e[0m"
            EXISTING_WAR=$(find "$REPO_PATH" -name "*.war" -path "*/target/*" | head -n 1)
            if [ -z "$EXISTING_WAR" ]; then
                echo -e "\e[31mErro: Modo fast ativado, mas nenhum arquivo .war foi encontrado em $REPO_PATH/target/.\e[0m"
                echo "Execute sem a flag -f uma vez para gerar o build."
                exit 1
            fi
        fi
        WAR_FILE=$(deploy_war "$REPO_PATH" "$RUNTIME_DIR")
        CONTEXT="${WAR_FILE%.war}"
        URL_PATH=""
        [ "$CONTEXT" != "ROOT" ] && URL_PATH="/$CONTEXT"
        HTTP_BASE=$(grep 'socket-binding name="http"' "$XML_PATH" | sed -n 's/.*port="\${[^:]*:\([^}]*\)}".*/\1/p')
        HTTP_BASE=${HTTP_BASE:-8080}
        FINAL_HTTP_PORT=$((HTTP_BASE + OFFSET))
        chmod +x "$WF_BASE_PATH/bin/standalone.sh"
        echo "================================================================"
        echo "Projeto: $NAME"
        echo "URL: http://localhost:$FINAL_HTTP_PORT$URL_PATH"
        echo "Offset Aplicado: $OFFSET"
        [ "$DEBUG" = true ] && echo "Debug Port: $FINAL_DEBUG_PORT"
        echo "================================================================"
        export JAVA_OPTS="$JVM_OPTS -Djboss.server.base.dir=$RUNTIME_DIR"
        "$WF_BASE_PATH/bin/standalone.sh" -b localhost -Djboss.socket.binding.port-offset=$OFFSET --server-config=standalone.xml
        ;;
    *)
        show_help
        ;;
esac